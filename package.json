    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-fetch": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "vite": "^6.2.0"
  },
