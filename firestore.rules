rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net (Pillar 0)
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives (Pillar 3 & 4)
    function isSignedIn() {
      return request.auth != null;
    }

    // A more lenient check for standard operations
    function isAuthed() {
      return isSignedIn();
    }

    // Use this for high-risk operations if needed, but avoid blocking login
    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isAuthed() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Entity Validations (Pillar 2)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt', 'trustScore', 'isVerified']) &&
             data.keys().size() <= 12 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.name is string &&
             data.role in ['tenant', 'landlord', 'admin'] &&
             data.createdAt == request.time; 
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['landlordId', 'title', 'description', 'location', 'price', 'propertyType', 'status', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.landlordId == request.auth.uid &&
             data.title is string && 
             data.price is number && 
             data.propertyType in ['apartment', 'house', 'studio'] &&
             (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidLease(data) {
      return data.keys().hasAll(['propertyId', 'tenantId', 'landlordId', 'startDate', 'endDate', 'rentAmount', 'status', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.status in ['pending', 'active', 'terminated', 'completed'] &&
             (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidMessage(data) {
       return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
              data.keys().size() == 3 &&
              data.senderId == request.auth.uid &&
              data.text is string && 
              data.createdAt == request.time;
    }

    // Match Blocks
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /saved_properties/{savedId} {
      allow read, write: if isSignedIn();
    }

    match /leases/{leaseId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    match /conversations/{convoId} {
      allow read: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn() && (incoming().tenantId == request.auth.uid || incoming().landlordId == request.auth.uid);
      allow update: if isSignedIn() && (existing().tenantId == request.auth.uid || existing().landlordId == request.auth.uid) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/conversations/$(convoId)).data.tenantId == request.auth.uid || 
                                       get(/databases/$(database)/documents/conversations/$(convoId)).data.landlordId == request.auth.uid);
        allow create: if isValidId(messageId) && isSignedIn() && isValidMessage(incoming()) && 
                      (get(/databases/$(database)/documents/conversations/$(convoId)).data.tenantId == request.auth.uid || 
                       get(/databases/$(database)/documents/conversations/$(convoId)).data.landlordId == request.auth.uid);
      }
    }

    match /reviews/{reviewId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && incoming().reviewerId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
