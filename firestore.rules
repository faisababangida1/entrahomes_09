rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net (Pillar 0)
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives (Pillar 3 & 4)
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isVerified() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Entity Validations (Pillar 2)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'createdAt', 'trustScore', 'isVerified']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['tenant', 'landlord', 'admin'] &&
             data.trustScore is number &&
             data.isVerified is bool &&
             data.createdAt == request.time; 
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['landlordId', 'title', 'description', 'location', 'price', 'propertyType', 'status', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.landlordId == request.auth.uid &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.location is string && data.location.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.propertyType in ['apartment', 'house', 'studio'] &&
             data.status in ['available', 'rented'] &&
             (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidLease(data) {
      return data.keys().hasAll(['propertyId', 'tenantId', 'landlordId', 'startDate', 'endDate', 'rentAmount', 'status', 'createdAt']) &&
             data.keys().size() <= 12 &&
             data.propertyId is string &&
             data.tenantId is string &&
             data.landlordId is string &&
             data.rentAmount is number &&
             data.status in ['pending', 'active', 'terminated', 'completed'] &&
             (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidMessage(data) {
       return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
              data.keys().size() == 3 &&
              data.senderId == request.auth.uid &&
              data.text is string && data.text.size() <= 5000 &&
              data.createdAt == request.time;
    }

    // Match Blocks
    match /users/{userId} {
      // Pillar 6: PII isolation. Since we don't have a split collection yet, 
      // we restrict get to verified users or owners.
      allow get: if isVerified() || isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Listing all users is admin-only.
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    (isOwner(userId) ? (
                      incoming().role == existing().role &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'trustScore', 'isVerified', 'email'])
                    ) : true);
    }

    match /properties/{propertyId} {
      // Pillar 8: Secure list queries.
      allow list: if resource.data.status == 'available';
      allow get: if true; // Properties are public.
      
      allow create: if isValidId(propertyId) && hasRole('landlord') && isValidProperty(incoming());
      allow update: if (isAdmin() || (isVerified() && existing().landlordId == request.auth.uid)) && 
                    isValidProperty(incoming()) &&
                    incoming().landlordId == existing().landlordId &&
                    (
                      // Action: General update
                      incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'location', 'price', 'propertyType', 'images', 'status'])
                    );
      allow delete: if isAdmin() || (isVerified() && existing().landlordId == request.auth.uid);
    }

    match /saved_properties/{savedId} {
      allow list: if isVerified() && resource.data.tenantId == request.auth.uid;
      allow get: if isVerified() && resource.data.tenantId == request.auth.uid;
      allow create: if isVerified() && hasRole('tenant') && incoming().tenantId == request.auth.uid;
      allow delete: if isVerified() && existing().tenantId == request.auth.uid;
    }

    match /leases/{leaseId} {
      allow read: if isVerified() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid || isAdmin());
      allow create: if isVerified() && hasRole('tenant') && incoming().tenantId == request.auth.uid && isValidLease(incoming());
      allow update: if isVerified() && isValidLease(incoming()) && (
        (existing().landlordId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read: if isVerified() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn(); // Any user can trigger a notification.
      allow update: if isVerified() && resource.data.recipientId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isVerified() && resource.data.recipientId == request.auth.uid;
    }

    match /conversations/{convoId} {
      allow read: if isVerified() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isVerified() && (incoming().tenantId == request.auth.uid || incoming().landlordId == request.auth.uid);
      allow update: if isVerified() && (existing().tenantId == request.auth.uid || existing().landlordId == request.auth.uid) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt']);

      match /messages/{messageId} {
        allow read: if isVerified() && (getUserData(convoId).tenantId == request.auth.uid || 
                                       getUserData(convoId).landlordId == request.auth.uid);
        allow create: if isValidId(messageId) && isVerified() && isValidMessage(incoming()) && 
                      (get(/databases/$(database)/documents/conversations/$(convoId)).data.tenantId == request.auth.uid || 
                       get(/databases/$(database)/documents/conversations/$(convoId)).data.landlordId == request.auth.uid);
      }
    }

    match /reviews/{reviewId} {
      allow list: if true;
      allow get: if true;
      allow create: if isVerified() && incoming().reviewerId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
